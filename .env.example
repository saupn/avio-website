# Copy to .env.local and fill in. Forms degrade gracefully (return an error state)
# until BOTH services below are configured; the build/deploy never require them.

# --- Firestore (Firebase Admin SDK) — server-side form writes ---
# From a Firebase service-account JSON. Keep the private key's newlines escaped as \n.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Upstash Redis — form rate limiting (5 requests / 10 min / IP) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
